.DS_Store
.build/
.swiftpm/
build/
DerivedData/
*.xcodeproj
dist/
*.app
*.dmg
xcuserdata/
Package.resolved

# Secrets — belt and braces. Real keys live in
# ~/Library/Application Support/VOCA/settings.json (outside the repo).
# These patterns block accidental commits if a dev ever drops one in here.
.env
.env.*
*.p12
*.cer
*.pem
*.key
*.keychain
*.keychain-db
settings.json
log.jsonl
secrets/

# Personal-data store files. They live in ~/Library/Application Support/
# VOCA/ but these patterns block accidental copies in the repo too.
dictionary.json
memory.json
history.json
learn_gate.json
learn_metrics.json

# Local design / icon experiments — kept out of the repo to avoid bloat.
Resources/logo-variants/

# Editor / tool backup files.
*.bak
